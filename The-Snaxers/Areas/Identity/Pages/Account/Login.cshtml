@page
@using TheSnaxers.Areas.Identity.Pages.Account
@model LoginModel
@{
    ViewData["Title"] = "Logga in";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">

            @* Felmeddelanden *@
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
            }

            @* ===== AC1: Logga in med Google ===== *@
            @if (Model.ExternalLogins?.Count > 0)
            {
                <div class="card shadow mb-4">
                    <div class="card-body p-4 text-center">
                        <h2 class="h4 mb-4">Logga in</h2>
                        <form asp-page="./ExternalLogin" asp-page-handler="post" method="post">
                            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                @if (provider.Name == "Google")
                                {
                                    <button type="submit" name="provider" value="@provider.Name"
                                            class="btn btn-outline-dark btn-lg w-100 d-flex align-items-center justify-content-center gap-2">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 48 48">
                                            <path fill="#FFC107" d="M43.6 20.1H42V20H24v8h11.3C33.7 32.7 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.8 1.1 7.9 3l5.7-5.7C34.5 6.7 29.6 4.5 24 4.5 13.2 4.5 4.5 13.2 4.5 24S13.2 43.5 24 43.5c10.5 0 19.3-7.6 20.9-17.5.2-1 .2-2 .2-3-.1-.7-.1-1.4-.1-2.9z"/>
                                            <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.4 16 18.9 12 24 12c3.1 0 5.8 1.1 7.9 3l5.7-5.7C34.5 6.7 29.6 4.5 24 4.5c-7.8 0-14.5 4.4-18 10.8-.2.4-.5.9-.7 1.4z"/>
                                            <path fill="#4CAF50" d="M24 43.5c5.5 0 10.4-2.1 14.1-5.5l-6.5-5.5C29.6 34.5 27 35.5 24 35.5c-5.2 0-9.6-3.2-11.3-7.8l-6.6 5.1C9.5 39.1 16.2 43.5 24 43.5z"/>
                                            <path fill="#1976D2" d="M43.6 20.1H42V20H24v8h11.3c-.8 2.2-2.3 4.1-4.2 5.4l6.5 5.5C37 39.4 43.5 33 43.5 24c0-1.3-.1-2.6-.4-3.9z"/>
                                        </svg>
                                        Logga in med Google
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" name="provider" value="@provider.Name"
                                            class="btn btn-outline-secondary w-100 mt-2">
                                        Logga in med @provider.DisplayName
                                    </button>
                                }
                            }
                        </form>
                    </div>
                </div>
                <div class="text-center text-muted mb-3"><span>— eller logga in med e-post —</span></div>
            }

            @* ===== E-post & lösenord ===== *@
            <div class="card shadow">
                <div class="card-body p-4">
                    <h2 class="h5 mb-3">E-post & lösenord</h2>
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label">E-postadress</label>
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label">Lösenord</label>
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>
                        <div class="mb-3 form-check">
                            <input asp-for="Input.RememberMe" class="form-check-input" />
                            <label asp-for="Input.RememberMe" class="form-check-label">Kom ihåg mig</label>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Logga in</button>
                    </form>
                    <div class="mt-3 text-center small">
                        <a asp-page="./ForgotPassword">Glömt lösenordet?</a> ·
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Registrera nytt konto</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
