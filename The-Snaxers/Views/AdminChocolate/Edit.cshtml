@model TheSnaxers.Models.Product

@{
    ViewData["Title"] = "Redigera choklad";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-dark text-white">
                    <h2 class="h4 mb-0">Redigera @Model.Name</h2>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" name="originalCategory" value="@Model.Category" />

    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold">Produktnamn</label>
                <input asp-for="Name" class="form-control shadow-sm" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Brand" class="form-label fw-bold">Varumärke</label>
                <input asp-for="Brand" class="form-control shadow-sm" />
                <span asp-validation-for="Brand" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-6">
                    <div class="mb-3">
                        <label asp-for="Price" class="form-label fw-bold">Pris (kr)</label>
                        <input asp-for="Price" type="number" step="0.01" class="form-control shadow-sm" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-6">
                    <div class="mb-3">
                        <label asp-for="CocoaPercentage" class="form-label fw-bold">Kakaohalt (%)</label>
                        <input asp-for="CocoaPercentage" type="number" class="form-control shadow-sm" />
                        <span asp-validation-for="CocoaPercentage" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="mb-3">
                <label asp-for="Country" class="form-label fw-bold">Ursprungsland</label>
                <input asp-for="Country" class="form-control shadow-sm" />
            </div>

            <div class="mb-3">
                <label asp-for="Category" class="form-label fw-bold">Kategori</label>
                <select asp-for="Category" class="form-select shadow-sm">
                    <option value="">-- Välj kategori --</option>
                    <option value="Mörk Choklad">Mörk Choklad</option>
                    <option value="Ljus Choklad">Ljus Choklad</option>
                    <option value="Vit Choklad">Vit Choklad</option>
                    <option value="Smaksatt">Smaksatt</option>
                </select>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>
        </div>

        @* MODIFIERING 2: Vi byter ut Text-input mot en Fil-input *@
                    <div class="col-12 mt-2">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Ladda upp produktbild</label>
                            <input type="file" name="imageFile" class="form-control shadow-sm" accept="image/*" />
                            <span class="text-muted small">Välj en bild från din dator för att ladda upp till galleriet.</span>
                            
                            @* Vi behåller den dolda ImageUrl så att modellen fortfarande är giltig, 
                               men användaren ser den inte *@
                            <input type="hidden" asp-for="ImageUrl" />
                        </div>
                    </div>

        <div class="col-12 mt-2">
            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-bold">Beskrivning</label>
                <textarea asp-for="Description" class="form-control shadow-sm" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-primary px-4 shadow-sm">
            <i class="bi bi-save2"></i> Spara ändringar
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary px-4 shadow-sm">
            <i class="bi bi-arrow-left-circle"></i> Tillbaka till listan
        </a>
    </div>
</form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $.validator.methods.number = function (value, element) {
            return this.optional(element) || /^-?(?:\d+|\d{1,3}(?:[\s,]\d{3})+)(?:[.,]\d+)?$/.test(value);
        }
    </script>
}