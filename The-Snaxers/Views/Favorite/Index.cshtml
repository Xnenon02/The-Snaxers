@model List<TheSnaxers.Models.Favorite>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="display-6">❤️ Mina favoriter</h2>
        <span class="badge bg-snaxers-gold rounded-pill">@Model.Count st sparade</span>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 shadow-sm rounded bg-light border">
            <img src="/images/empty-cart-choco.jpg" 
                 alt="Tom chokladask" 
                 class="img-fluid mb-4" 
                 style="max-height: 250px; opacity: 0.8;">
            
            <p class="lead text-muted mb-4">Här var det tomt! Din choklad-samling väntar på att fyllas. 🍫</p>
            
            <a asp-controller="Chocolate" asp-action="Index" class="btn btn-snaxers-gold btn-lg shadow-sm">
                <i class="bi bi-search"></i> Hitta din favorit
            </a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm snaxers-card">
                        <div class="position-relative">
                            <img src="@item.Product?.ImageUrl" 
                                class="card-img-top p-4" 
                                alt="@item.Product?.Name" 
                                style="height: 200px; object-fit: contain;">
                            
                            <form asp-controller="Favorite" asp-action="Remove" method="post" class="position-absolute top-0 end-0 m-2">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <input type="hidden" name="returnUrl" value="Favorite" />
                                <button type="submit" 
        class="btn-close bg-white shadow-sm p-2 rounded-circle" 
        title="Ta bort från favoriter" 
        aria-label="Ta bort @item.Product?.Name från favoriter">
</button>
                            </form>
                        </div>

                        <div class="card-body d-flex flex-column text-center">
                            <h5 class="card-title fw-bold">@item.Product?.Name</h5>
                            <p class="card-text text-muted mb-2">@item.Product?.Brand</p>
                            <div class="mt-auto">
                                <p class="h5 text-snaxers-dark mb-3">@item.Product?.Price.ToString("C")</p>
                                
                                <div class="d-grid gap-2">
                                    @* Framtida US: Lägg i varukorg 
                                    <button class="btn btn-snaxers-gold">
                                        <i class="bi bi-cart-plus"></i> Lägg i varukorg
                                    </button>*@
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>