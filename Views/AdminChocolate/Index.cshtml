@model IEnumerable<TheSnaxers.Models.Product>

@{
    ViewData["Title"] = "Admin - Hantera Choklad";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5">Lagerhantering</h1>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Lägg till ny choklad
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Bild</th>
            <th>Namn</th>
            <th>Märke</th>
            <th>Kakaohalt</th>
            <th>Status</th> @* NY KOLUMN *@
            <th class="text-end">Åtgärder</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
{
    @* Vi simulerar ett lagersaldo baserat på ID och namnlängd *@
    var fakeStock = (item.Id % 3 == 0) ? 0 : (item.Name.Length * 2);

    <tr>
        <td>
            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/placeholder-choco.png" : item.ImageUrl)" 
                 alt="@item.Name" style="width: 50px; height: 50px; object-fit: cover;" class="rounded shadow-sm">
        </td>
        <td class="fw-bold">@item.Name</td>
        <td>@item.Brand</td>
        <td><span class="badge bg-info text-dark">@item.CocoaPercentage%</span></td>
        
        @* SIMULERAT LAGERSALDO *@
        <td>
            @if (fakeStock > 15)
            {
                <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle">
                    <i class="bi bi-check-circle"></i> I lager (@fakeStock)
                </span>
            }
            else if (fakeStock > 0)
            {
                <span class="badge rounded-pill bg-warning-subtle text-warning-emphasis border border-warning-subtle">
                    <i class="bi bi-exclamation-triangle"></i> Få kvar (@fakeStock)
                </span>
            }
            else
            {
                <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger-subtle">
                    <i class="bi bi-x-circle"></i> Slut i lager
                </span>
            }
        </td>

        <td class="text-end">
            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary shadow-sm">
                    <i class="bi bi-pencil-square"></i> Ändra
                </a>

                <form asp-action="Delete" asp-route-id="@item.Id" method="post" 
                      onsubmit="return confirm('Är du helt säker på att du vill ta bort @item.Name?')">
                    <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm">
                        <i class="bi bi-trash3"></i> Ta bort
                    </button>
                </form>
            </div>
        </td>
    </tr>
}
    </tbody>
</table>
        </div>
    </div>
</div>