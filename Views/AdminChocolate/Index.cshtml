@model IEnumerable<TheSnaxers.Models.Product>

@{
    ViewData["Title"] = "Admin - Hantera Choklad";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5">Lagerhantering</h1>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Lägg till ny choklad
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Bild</th>
                        <th>Namn</th>
                        <th>Märke</th>
                        <th>Kakaohalt</th>
                        <th class="text-end">Åtgärder</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/placeholder-choco.png" : item.ImageUrl)" 
                                     alt="@item.Name" style="width: 50px; height: 50px; object-fit: cover;" class="rounded shadow-sm">
                            </td>
                            <td class="fw-bold">@item.Name</td>
                            <td>@item.Brand</td>
                            <td><span class="badge bg-info text-dark">@item.CocoaPercentage%</span></td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    @* Ändra-knappen är fortfarande en vanlig länk (GET) *@
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-pencil"></i> Ändra
                                    </a>

                                    @* Ta bort-knappen är nu ett FORM för att fungera med [HttpPost] *@
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" 
                                          onsubmit="return confirm('Är du helt säker på att du vill ta bort @item.Name?')">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-trash"></i> Ta bort
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>