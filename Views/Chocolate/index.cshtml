@model IEnumerable<TheSnaxers.ViewModels.ChocolateGalleryViewModel>

@{
    ViewData["Title"] = "Chokladgalleriet";
}

@section Styles {
    <link rel="stylesheet" href="~/css/chocolate-gallery.css" asp-append-version="true" />
}

<div class="container mt-4">
    <h1 class="text-center mb-5 display-4 shadow-text">Vårt Chokladutbud</h1>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var chocolate in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm hover-shadow transition">
                    
                    <div class="position-relative">
                        <img src="@(string.IsNullOrEmpty(chocolate.ImageUrl) ? "/images/placeholder-choco.png" : chocolate.ImageUrl)" 
                             class="card-img-top p-3 choco-card-img" 
                             alt="@chocolate.Name">
                        
                        <div class="position-absolute bottom-0 end-0 m-2 shadow-sm bg-white p-1 rounded">
                            <img src="@chocolate.FlagUrl" alt="@chocolate.CountryName" title="@chocolate.CountryName" class="flag-badge">
                        </div>
                    </div>

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold">@chocolate.Name</h5>
                        <p class="text-muted mb-3 small">Ursprung: @chocolate.CountryName</p>
                        
                        <div class="mt-auto d-flex justify-content-between align-items-center">
                            <button class="btn btn-outline-primary btn-sm">Läs mer</button>
                            <i class="bi bi-heart text-danger" style="cursor: pointer;"></i> 
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>