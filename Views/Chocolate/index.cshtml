@model IEnumerable<TheSnaxers.ViewModels.ChocolateGalleryViewModel>

@{
    ViewData["Title"] = "Chokladgalleriet";
}

@section Styles {
    <link rel="stylesheet" href="~/css/chocolate-gallery.css" asp-append-version="true" />
}

<div class="container mt-4">
    <h1 class="text-center mb-5 display-4 shadow-text">Vårt Chokladutbud</h1>

    <form asp-controller="Chocolate" asp-action="Index" method="get" class="mb-4">
        <div class="row g-2">
            <div class="col-md-6">
                <input type="text" name="searchTerm" value="@ViewBag.SearchTerm"
                       class="form-control" placeholder="Sök på namn..." />
            </div>
            <div class="col-md-4">
                <select name="minCocoa" class="form-select">
                    <option value="">Alla kakaohalter</option>
                    <option value="50" selected="@(ViewBag.MinCocoa == 50)">50% eller mer</option>
                    <option value="70" selected="@(ViewBag.MinCocoa == 70)">70% eller mer</option>
                    <option value="85" selected="@(ViewBag.MinCocoa == 85)">85% eller mer</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-dark w-100">Sök</button>
            </div>
        </div>
    </form>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center my-5 p-5 border rounded bg-light">
            <img src="~/images/nochoc.png" alt="Ingen choklad hittades" class="mb-4" style="max-width: 300px; opacity: 0.8;">
            <p class="lead text-muted">Ingen choklad hittades för tillfället.</p>
            <p>Kom gärna tillbaka senare eller kontakta vår chokladmästare.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var chocolate in Model)
            {
                var isFavorite = ((List<int>)ViewBag.FavoriteIds)?.Contains(chocolate.Id) ?? false;
                <div class="col">
                    <div class="flip-card" onclick="this.classList.toggle('flipped')">
                        <div class="flip-card-inner">

                            @* FRAMSIDA *@
                            <div class="flip-card-front card h-100 shadow-sm hover-shadow transition">
                                <div class="position-relative">
                                    
                                    @* Bild med fallback *@
                                    <img src="@(string.IsNullOrEmpty(chocolate.DynamicImageUrl) ? "/images/placeholder-choco.png" : chocolate.DynamicImageUrl)" 
                                         class="card-img-top choco-card-img" 
                                         alt="@chocolate.Name">

                                    @if (chocolate.CocoaPercentage > 0)
                                    {
                                        <div class="position-absolute top-0 start-0 m-3 badge bg-dark fs-6 shadow-sm">
                                            @chocolate.CocoaPercentage% Kakao
                                        </div>
                                    }

                                    <div class="position-absolute bottom-0 end-0 m-2 shadow-sm bg-white p-1 rounded">
                                        @if (!string.IsNullOrEmpty(chocolate.FlagUrl))
                                        {
                                            <img src="@chocolate.FlagUrl" alt="@chocolate.CountryName" title="@chocolate.CountryName" class="flag-badge" style="max-width: 30px;">
                                        }
                                        else
                                        {
                                            <span title="@chocolate.CountryName" style="font-size:20px;">🌍</span>
                                        }
                                    </div>
                                </div>

                                <div class="card-body d-flex flex-column p-3">
                                    <h5 class="card-title fw-bold">@chocolate.Name</h5>
                                    <p class="text-muted mb-3 small">Ursprung: @chocolate.CountryName</p>
                                    
                                    <div class="mt-auto d-flex justify-content-between align-items-center">
                                        <button class="btn btn-outline-primary btn-sm" onclick="event.stopPropagation(); this.closest('.flip-card').classList.add('flipped')">Läs mer</button>
                                        
                                        <div class="favorite-zone" onclick="event.stopPropagation()">
                                            <form asp-controller="Favorite" asp-action="@(isFavorite ? "Remove" : "Add")" method="post" class="d-inline">
                                                <input type="hidden" name="productId" value="@chocolate.Id" />
                                                <input type="hidden" name="returnUrl" value="Chocolate" />
                                                <button type="submit" class="btn btn-link p-0 text-decoration-none">
                                                    <i class="bi @(isFavorite ? "bi-heart-fill" : "bi-heart") text-danger fs-4"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            @* BAKSIDA *@
                            <div class="flip-card-back p-4 d-flex flex-column justify-content-center align-items-center text-center">
                                <h5>@chocolate.Name</h5>
                                @if (chocolate.CocoaPercentage > 0)
                                {
                                    <span class="badge-cocoa mb-2 d-inline-block">🍫 @chocolate.CocoaPercentage% Kakao</span>
                                }
                                <p>@chocolate.Description</p>
                                <p class="mb-1">🌍 Ursprung: @chocolate.CountryName</p>
                                @if (!string.IsNullOrEmpty(chocolate.Brand))
                                {
                                    <p class="mb-1">✨ Märke: @chocolate.Brand</p>
                                }
                                <p class="fw-bold mt-2">💰 Pris: @chocolate.Price kr</p>
                                
                                <button class="flip-back-btn mt-3 btn btn-outline-light btn-sm" onclick="event.stopPropagation(); this.closest('.flip-card').classList.remove('flipped')">
                                    ← Tillbaka
                                </button>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>