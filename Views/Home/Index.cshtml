@section Styles {
    <link rel="stylesheet" href="~/css/landing-page.css" asp-append-version="true" />
}

<div class="landing-hero d-flex align-items-center justify-content-center">
    <div class="text-center text-white p-5 glass-card shadow-lg">
        <h1 class="display-2 fw-bold mb-3">The Snaxers</h1>
        <p class="lead fs-3 mb-4">Upplev premiumchoklad från världens alla hörn.</p>
        <hr class="my-4 border-light opacity-50">
        <p class="mb-5 italic">Handplockade favoriter, direkt till din dörr.</p>
        
        <a asp-controller="Chocolate" asp-action="Index" class="btn btn-gold btn-lg px-5 py-3 fw-bold shadow-sm">
            Utforska Galleriet <i class="bi bi-arrow-right ms-2"></i>
        </a>
    </div>
</div>